{
    "projectId": "69d2a9900032fd99f3b7",
    "projectName": "alpacca",
    "endpoint": "https://sgp.cloud.appwrite.io/v1",
    "settings": {
        "services": {
            "account": true,
            "avatars": true,
            "databases": true,
            "locale": true,
            "health": true,
            "storage": true,
            "teams": true,
            "users": true,
            "sites": true,
            "functions": true,
            "graphql": true,
            "messaging": true
        },
        "auth": {
            "methods": {
                "jwt": true,
                "phone": true,
                "invites": true,
                "anonymous": true,
                "email-otp": true,
                "magic-url": true,
                "email-password": true
            },
            "security": {
                "duration": 31536000,
                "limit": 0,
                "sessionsLimit": 10,
                "passwordHistory": 0,
                "passwordDictionary": false,
                "personalDataCheck": false,
                "sessionAlerts": false,
                "mockNumbers": []
            }
        }
    },
    "tablesDB": [
        {
            "$id": "medical_data",
            "name": "MedicalData",
            "enabled": true
        }
    ],
    "tables": [
        {
            "$id": "reports",
            "$permissions": [
                "create(\"users\")",
                "read(\"users\")",
                "update(\"users\")"
            ],
            "databaseId": "medical_data",
            "name": "reports",
            "enabled": true,
            "rowSecurity": false,
            "columns": [
                {
                    "key": "userId",
                    "type": "string",
                    "required": true,
                    "array": false,
                    "size": 255,
                    "default": null,
                    "encrypt": false
                },
                {
                    "key": "fileId",
                    "type": "string",
                    "required": true,
                    "array": false,
                    "size": 255,
                    "default": null,
                    "encrypt": false
                },
                {
                    "key": "fileName",
                    "type": "string",
                    "required": true,
                    "array": false,
                    "size": 255,
                    "default": null,
                    "encrypt": false
                },
                {
                    "key": "status",
                    "type": "string",
                    "required": true,
                    "array": false,
                    "size": 255,
                    "default": null,
                    "encrypt": false
                },
                {
                    "key": "reportType",
                    "type": "string",
                    "required": false,
                    "array": false,
                    "size": 255,
                    "default": null,
                    "encrypt": false
                },
                {
                    "key": "reportDate",
                    "type": "datetime",
                    "required": false,
                    "array": false,
                    "default": null,
                    "format": ""
                },
                {
                    "key": "extractedText",
                    "type": "string",
                    "required": false,
                    "array": false,
                    "size": 65535,
                    "default": null,
                    "encrypt": false
                },
                {
                    "key": "structuredData",
                    "type": "string",
                    "required": false,
                    "array": false,
                    "size": 65535,
                    "default": null,
                    "encrypt": false
                }
            ],
            "indexes": []
        }
    ],
    "buckets": [
        {
            "$id": "reports_bucket",
            "$permissions": [
                "create(\"users\")",
                "read(\"users\")",
                "update(\"users\")",
                "delete(\"users\")"
            ],
            "fileSecurity": false,
            "name": "Reports",
            "enabled": true,
            "maximumFileSize": 50000000,
            "allowedFileExtensions": [
                "jpg",
                "png",
                "jpeg",
                "pdf"
            ],
            "compression": "none",
            "encryption": true,
            "antivirus": true
        }
    ],
    "functions": [
        {
            "$id": "analyze-report",
            "name": "Analyze Medical Report (Azure AI)",
            "runtime": "node-18.0",
            "execute": [
                "any"
            ],
            "events": [
                "databases.medical_data.collections.reports.documents.*.create"
            ],
            "schedule": "",
            "timeout": 60,
            "path": "functions/analyze-report",
            "entrypoint": "src/main.js",
            "ignore": [
                ".npm"
            ]
        }
    ]
}